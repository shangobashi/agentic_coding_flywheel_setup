#!/usr/bin/env bash
# ============================================================
# ACFS Global Wrapper
# Installed to /usr/local/bin/acfs for system-wide access
#
# This wrapper ensures the acfs command works regardless of
# which user invokes it (root or target user).
# ============================================================

set -euo pipefail

# Optional override for state file location.
# If unset, we auto-detect from common install locations.
ACFS_STATE_FILE="${ACFS_STATE_FILE:-}"
ACFS_SYSTEM_STATE_FILE="${ACFS_SYSTEM_STATE_FILE:-/var/lib/acfs/state.json}"

is_valid_username() {
    local username="$1"
    [[ "$username" =~ ^[a-z_][a-z0-9_-]*$ ]]
}

resolve_home_for_user() {
    local user="$1"
    local user_home=""

    if [[ "$user" == "root" ]]; then
        printf '/root\n'
        return 0
    fi

    user_home="$(getent passwd "$user" 2>/dev/null | cut -d: -f6)" || true
    if [[ -n "$user_home" ]] && [[ "$user_home" == /* ]]; then
        printf '%s\n' "${user_home%/}"
        return 0
    fi

    return 1
}

read_target_user_from_state_file() {
    local state_file="$1"
    local target_user=""

    [[ -f "$state_file" ]] || return 1

    # Try jq first (faster and more reliable)
    if command -v jq &>/dev/null; then
        target_user="$(jq -r '.target_user // empty' "$state_file" 2>/dev/null || true)"
    fi

    # Fall back to sed if jq not available / parse fails
    if [[ -z "$target_user" ]]; then
        target_user="$(sed -n 's/.*"target_user"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$state_file" | head -n 1)"
    fi

    if [[ -n "$target_user" ]] && is_valid_username "$target_user"; then
        printf '%s\n' "$target_user"
        return 0
    fi

    return 1
}

read_target_home_from_state_file() {
    local state_file="$1"
    local target_home=""

    [[ -f "$state_file" ]] || return 1

    if command -v jq &>/dev/null; then
        target_home="$(jq -r '.target_home // empty' "$state_file" 2>/dev/null || true)"
    fi

    if [[ -z "$target_home" ]]; then
        target_home="$(sed -n 's/.*"target_home"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$state_file" | head -n 1)"
    fi

    if [[ -n "$target_home" ]] && [[ "$target_home" == /* ]] && [[ "$target_home" != "/" ]]; then
        printf '%s\n' "${target_home%/}"
        return 0
    fi

    return 1
}

find_acfs_bin_from_state_file() {
    local state_file="$1"
    local state_home=""
    local target_home=""
    local target_user=""
    local candidate_bin=""

    [[ -f "$state_file" ]] || return 1

    if [[ "$state_file" == */.acfs/state.json ]]; then
        state_home="${state_file%/.acfs/state.json}"
        state_home="${state_home%/}"
        if [[ -n "$state_home" ]] && [[ "$state_home" == /* ]] && [[ "$state_home" != "/" ]]; then
            candidate_bin="$(find_acfs_bin_for_home "$state_home" 2>/dev/null || true)"
            if [[ -n "$candidate_bin" ]]; then
                printf '%s\n' "$candidate_bin"
                return 0
            fi

            # For home-adjacent state files, the path is a stronger signal than
            # any embedded target_user copied from another install.
            return 1
        fi
    fi

    target_home="$(read_target_home_from_state_file "$state_file" 2>/dev/null || true)"
    if [[ -n "$target_home" ]]; then
        candidate_bin="$(find_acfs_bin_for_home "$target_home" 2>/dev/null || true)"
        if [[ -n "$candidate_bin" ]]; then
            printf '%s\n' "$candidate_bin"
            return 0
        fi
    fi

    target_user="$(read_target_user_from_state_file "$state_file" 2>/dev/null || true)"
    [[ -n "$target_user" ]] || return 1
    find_acfs_bin "$target_user"
}

find_acfs_bin_for_home() {
    local user_home="$1"

    [[ -n "$user_home" ]] || return 1

    if [[ -x "$user_home/.local/bin/acfs" ]]; then
        printf '%s\n' "$user_home/.local/bin/acfs"
        return 0
    fi

    if [[ -x "$user_home/.acfs/bin/acfs" ]]; then
        printf '%s\n' "$user_home/.acfs/bin/acfs"
        return 0
    fi

    return 1
}

home_from_acfs_bin() {
    local acfs_bin="$1"
    local user_home=""

    [[ -n "$acfs_bin" ]] || return 1

    case "$acfs_bin" in
        */.local/bin/acfs)
            user_home="${acfs_bin%/.local/bin/acfs}"
            ;;
        */.acfs/bin/acfs)
            user_home="${acfs_bin%/.acfs/bin/acfs}"
            ;;
        *)
            return 1
            ;;
    esac

    [[ -n "$user_home" ]] || return 1
    [[ "$user_home" == /* ]] || return 1
    [[ "$user_home" != "/" ]] || return 1
    printf '%s\n' "${user_home%/}"
}

prepare_runtime_context_from_home() {
    local user_home="$1"

    [[ -n "$user_home" ]] || return 1
    [[ "$user_home" == /* ]] || return 1
    [[ "$user_home" != "/" ]] || return 1

    TARGET_HOME="$user_home"
    ACFS_HOME="$user_home/.acfs"
    ACFS_STATE_FILE="$ACFS_HOME/state.json"

    export TARGET_HOME ACFS_HOME ACFS_STATE_FILE
}

read_user_for_home() {
    local user_home="$1"
    local candidate_user=""
    local state_file=""
    local state_home=""

    [[ -n "$user_home" ]] || return 1
    state_file="$user_home/.acfs/state.json"
    user_home="${user_home%/}"

    candidate_user="$(
        getent passwd 2>/dev/null \
            | awk -F: -v home="$user_home" '$6 == home { print $1; exit }'
    )" || true
    if [[ -n "$candidate_user" ]] && is_valid_username "$candidate_user"; then
        printf '%s\n' "$candidate_user"
        return 0
    fi

    if command -v stat >/dev/null 2>&1; then
        candidate_user="$(stat -c '%U' "$user_home" 2>/dev/null || true)"
        if [[ -n "$candidate_user" ]] && [[ "$candidate_user" != "UNKNOWN" ]] && is_valid_username "$candidate_user"; then
            printf '%s\n' "$candidate_user"
            return 0
        fi
    fi

    candidate_user="$(read_target_user_from_state_file "$state_file" 2>/dev/null || true)"
    [[ -n "$candidate_user" ]] || return 1

    state_home="$(read_target_home_from_state_file "$state_file" 2>/dev/null || true)"
    if [[ -z "$state_home" ]]; then
        state_home="$(getent passwd "$candidate_user" 2>/dev/null | cut -d: -f6)" || true
        state_home="${state_home%/}"
    fi

    if [[ -n "$state_home" ]] && [[ "$state_home" == "$user_home" ]]; then
        printf '%s\n' "$candidate_user"
        return 0
    fi

    return 1
}

read_target_user_from_state_hint() {
    local state_file="$1"
    local candidate_user=""
    local state_home=""

    [[ -f "$state_file" ]] || return 1

    if [[ "$state_file" == */.acfs/state.json ]]; then
        state_home="${state_file%/.acfs/state.json}"
        state_home="${state_home%/}"
        if [[ -n "$state_home" ]] && [[ "$state_home" == /* ]] && [[ "$state_home" != "/" ]]; then
            candidate_user="$(read_user_for_home "$state_home" 2>/dev/null || true)"
            if [[ -n "$candidate_user" ]] && find_acfs_bin_for_home "$state_home" >/dev/null 2>&1; then
                printf '%s\n' "$candidate_user"
                return 0
            fi

            # For home-adjacent state files, refuse to trust mismatched target_user
            # values from stale copies. The path itself is the stronger signal.
            return 1
        fi
    fi

    state_home="$(read_target_home_from_state_file "$state_file" 2>/dev/null || true)"
    if [[ -n "$state_home" ]] && [[ "$state_home" == /* ]] && [[ "$state_home" != "/" ]]; then
        candidate_user="$(read_user_for_home "$state_home" 2>/dev/null || true)"
        if [[ -z "$candidate_user" ]]; then
            candidate_user="$(read_target_user_from_state_file "$state_file" 2>/dev/null || true)"
        fi
        if [[ -n "$candidate_user" ]] && find_acfs_bin_for_home "$state_home" >/dev/null 2>&1; then
            printf '%s\n' "$candidate_user"
            return 0
        fi
    fi

    candidate_user="$(read_target_user_from_state_file "$state_file" 2>/dev/null || true)"
    if [[ -n "$candidate_user" ]] && find_acfs_bin "$candidate_user" >/dev/null 2>&1; then
        printf '%s\n' "$candidate_user"
        return 0
    fi

    return 1
}

# Find acfs installation for a user
find_acfs_bin() {
    local user="$1"
    local user_home=""
    local current_user=""

    user_home="$(resolve_home_for_user "$user" || true)"
    if [[ -n "$user_home" ]] && find_acfs_bin_for_home "$user_home" >/dev/null 2>&1; then
        find_acfs_bin_for_home "$user_home"
        return 0
    fi

    current_user="$(id -un 2>/dev/null || whoami 2>/dev/null || true)"
    if [[ "$current_user" == "$user" ]] && [[ -n "${HOME:-}" ]] && [[ "${HOME}" == /* ]]; then
        user_home="${HOME%/}"
        if find_acfs_bin_for_home "$user_home" >/dev/null 2>&1; then
            find_acfs_bin_for_home "$user_home"
            return 0
        fi
    fi

    return 1
}

find_installed_acfs_owner() {
    local current_user=""
    local candidate_user=""
    local candidate_home=""

    current_user="$(whoami 2>/dev/null || true)"
    if [[ -n "$current_user" ]] && find_acfs_bin "$current_user" >/dev/null 2>&1; then
        printf '%s\n' "$current_user"
        return 0
    fi

    while IFS=: read -r candidate_user _ _ _ _ candidate_home _; do
        [[ -n "$candidate_user" ]] || continue
        [[ -n "$candidate_home" ]] || continue
        [[ "$candidate_home" == /* ]] || continue
        if find_acfs_bin_for_home "$candidate_home" >/dev/null 2>&1; then
            printf '%s\n' "$candidate_user"
            return 0
        fi
    done < <(getent passwd 2>/dev/null || true)

    return 1
}

# Detect target user from state file(s) or installed homes.
detect_target_user() {
    local current_user=""
    local state_candidate=""
    local candidate_user=""
    local candidate_home=""
    local acfs_home="${ACFS_HOME:-}"

    current_user="$(whoami 2>/dev/null || true)"
    if [[ -n "$current_user" ]] && find_acfs_bin "$current_user" >/dev/null 2>&1; then
        printf '%s\n' "$current_user"
        return 0
    fi

    if [[ -n "$acfs_home" ]]; then
        acfs_home="${acfs_home%/}"
        if [[ "$acfs_home" == */.acfs ]]; then
            candidate_home="${acfs_home%/.acfs}"
            candidate_user="$(read_user_for_home "$candidate_home" 2>/dev/null || true)"
            if [[ -n "$candidate_user" ]] && find_acfs_bin_for_home "$candidate_home" >/dev/null 2>&1; then
                printf '%s\n' "$candidate_user"
                return 0
            fi
        fi
        candidate_user="$(read_target_user_from_state_hint "$acfs_home/state.json" 2>/dev/null || true)"
        if [[ -n "$candidate_user" ]]; then
            printf '%s\n' "$candidate_user"
            return 0
        fi
    fi

    if [[ -n "${ACFS_STATE_FILE:-}" ]]; then
        candidate_user="$(read_target_user_from_state_hint "$ACFS_STATE_FILE" 2>/dev/null || true)"
        if [[ -n "$candidate_user" ]]; then
            printf '%s\n' "$candidate_user"
            return 0
        fi
    fi

    candidate_user="$(read_target_user_from_state_hint "$HOME/.acfs/state.json" 2>/dev/null || true)"
    if [[ -n "$candidate_user" ]]; then
        printf '%s\n' "$candidate_user"
        return 0
    fi

    while IFS=: read -r _ _ _ _ _ candidate_home _; do
        [[ -n "$candidate_home" ]] || continue
        [[ "$candidate_home" == /* ]] || continue
        state_candidate="$candidate_home/.acfs/state.json"
        candidate_user="$(read_target_user_from_state_hint "$state_candidate" 2>/dev/null || true)"
        if [[ -n "$candidate_user" ]]; then
            printf '%s\n' "$candidate_user"
            return 0
        fi
    done < <(getent passwd 2>/dev/null || true)

    candidate_user="$(read_target_user_from_state_hint "$ACFS_SYSTEM_STATE_FILE" 2>/dev/null || true)"
    if [[ -n "$candidate_user" ]]; then
        printf '%s\n' "$candidate_user"
        return 0
    fi

    candidate_user="$(find_installed_acfs_owner 2>/dev/null || true)"
    if [[ -n "$candidate_user" ]]; then
        printf '%s\n' "$candidate_user"
        return 0
    fi

    echo "ubuntu"
}

main() {
    local target_user
    local acfs_bin=""
    local current_user
    local runtime_home=""
    local runtime_user=""
    local candidate_bin=""

    target_user="$(detect_target_user)"
    current_user="$(whoami)"

    # Find the acfs binary
    if [[ -n "${ACFS_HOME:-}" ]] && [[ "${ACFS_HOME}" == */.acfs ]]; then
        candidate_bin="$(find_acfs_bin_for_home "${ACFS_HOME%/.acfs}" 2>/dev/null || true)"
        [[ -n "$candidate_bin" ]] && acfs_bin="$candidate_bin"
    fi

    if [[ -z "$acfs_bin" ]] && [[ -n "${ACFS_STATE_FILE:-}" ]]; then
        candidate_bin="$(find_acfs_bin_from_state_file "$ACFS_STATE_FILE" 2>/dev/null || true)"
        [[ -n "$candidate_bin" ]] && acfs_bin="$candidate_bin"
    fi

    if [[ -z "$acfs_bin" ]]; then
        candidate_bin="$(find_acfs_bin_from_state_file "$HOME/.acfs/state.json" 2>/dev/null || true)"
        [[ -n "$candidate_bin" ]] && acfs_bin="$candidate_bin"
    fi

    if [[ -z "$acfs_bin" ]] && [[ -n "${ACFS_SYSTEM_STATE_FILE:-}" ]]; then
        candidate_bin="$(find_acfs_bin_from_state_file "$ACFS_SYSTEM_STATE_FILE" 2>/dev/null || true)"
        [[ -n "$candidate_bin" ]] && acfs_bin="$candidate_bin"
    fi

    if [[ -z "$acfs_bin" ]]; then
        acfs_bin="$(find_acfs_bin "$target_user" || true)"
    fi

    if [[ -z "$acfs_bin" ]]; then
        echo "Error: ACFS not found for user '$target_user'" >&2

        local target_home=""
        target_home="$(resolve_home_for_user "$target_user" || true)"

        if [[ -n "$target_home" ]]; then
            echo "Expected at: $target_home/.local/bin/acfs (or $target_home/.acfs/bin/acfs)" >&2
        else
            echo "Unable to determine an exact home directory for user '$target_user'." >&2
            echo "Provide ACFS_STATE_FILE/ACFS_SYSTEM_STATE_FILE with target_home, or re-run from the installed ACFS tree." >&2
        fi

        local candidate_home=""
        local candidate_user=""
        local candidate_bin=""
        local found_candidates=0

        while IFS=: read -r candidate_user _ _ _ _ candidate_home _; do
            [[ -n "$candidate_user" ]] || continue
            [[ -n "$candidate_home" ]] || continue
            [[ "$candidate_home" == /* ]] || continue
            candidate_bin="$(find_acfs_bin_for_home "$candidate_home" 2>/dev/null || true)"
            [[ -n "$candidate_bin" ]] || continue
            if (( found_candidates == 0 )); then
                echo "" >&2
                echo "Detected other ACFS installs:" >&2
            fi
            found_candidates=1
            echo "  - $candidate_user: $candidate_bin" >&2
            echo "    Try: sudo -u \"$candidate_user\" -H -- \"$0\" [args...]" >&2
        done < <(getent passwd 2>/dev/null || true)

        echo "" >&2
        echo "If ACFS was installed for a different user, run this wrapper as that user, e.g.:" >&2
        echo "  sudo -u <user> -H -- \"$0\" [args...]" >&2
        echo "" >&2
        echo "You can also override state discovery:" >&2
        echo "  ACFS_STATE_FILE=/path/to/state.json \"$0\" [args...]" >&2
        exit 1
    fi

    runtime_home="$(home_from_acfs_bin "$acfs_bin" 2>/dev/null || true)"
    if [[ -n "$runtime_home" ]]; then
        prepare_runtime_context_from_home "$runtime_home"
        runtime_user="$(read_user_for_home "$runtime_home" 2>/dev/null || true)"
        if [[ -n "$runtime_user" ]]; then
            target_user="$runtime_user"
        fi
    fi

    exec_as_target_user() {
        local user="$1"
        shift
        local -a env_args=()

        [[ -n "${ACFS_STATE_FILE:-}" ]] && env_args+=("ACFS_STATE_FILE=$ACFS_STATE_FILE")
        [[ -n "${ACFS_SYSTEM_STATE_FILE:-}" ]] && env_args+=("ACFS_SYSTEM_STATE_FILE=$ACFS_SYSTEM_STATE_FILE")
        [[ -n "${TARGET_HOME:-}" ]] && env_args+=("TARGET_HOME=$TARGET_HOME")
        [[ -n "${ACFS_HOME:-}" ]] && env_args+=("ACFS_HOME=$ACFS_HOME")
        [[ -n "${ACFS_REF:-}" ]] && env_args+=("ACFS_REF=$ACFS_REF")
        [[ -n "${ACFS_RAW:-}" ]] && env_args+=("ACFS_RAW=$ACFS_RAW")

        local cmd_with_env
        if [[ ${#env_args[@]} -gt 0 ]]; then
            cmd_with_env=("env" "${env_args[@]}" "$@")
        else
            cmd_with_env=("$@")
        fi

        if [[ "$EUID" -eq 0 ]]; then
            if command -v runuser >/dev/null 2>&1; then
                exec runuser -u "$user" -- "${cmd_with_env[@]}"
            fi
            if command -v sudo >/dev/null 2>&1; then
                exec sudo -u "$user" -H "${cmd_with_env[@]}"
            fi
            echo "Error: need runuser or sudo to run acfs as '$user'" >&2
            exit 1
        fi

        if ! command -v sudo >/dev/null 2>&1; then
            echo "Error: need sudo to run acfs as '$user'" >&2
            exit 1
        fi

        echo "Note: Running acfs as '$user' (ACFS owner)" >&2
        exec sudo -u "$user" -H "${cmd_with_env[@]}"
    }

    # If we're already the target user, run directly
    if [[ "$current_user" == "$target_user" ]]; then
        if [[ -n "${TARGET_HOME:-}" ]]; then
            exec env HOME="$TARGET_HOME" TARGET_HOME="$TARGET_HOME" ACFS_HOME="${ACFS_HOME:-$TARGET_HOME/.acfs}" "$acfs_bin" "$@"
        fi
        exec "$acfs_bin" "$@"
    fi

    # IMPORTANT: Avoid `sudo -i` which sources shell profile files.
    # Third-party installers sometimes modify those files in ways that can
    # break non-interactive runs. We set HOME with `-H` but preserve CWD.
    exec_as_target_user "$target_user" "$acfs_bin" "$@"
}

main "$@"
