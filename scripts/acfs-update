#!/usr/bin/env bash
# ============================================================
# ACFS Update Wrapper
# Provides a global `acfs-update` command that dispatches to update.sh
# ============================================================

set -euo pipefail

ACFS_STATE_FILE="${ACFS_STATE_FILE:-}"
ACFS_SYSTEM_STATE_FILE="${ACFS_SYSTEM_STATE_FILE:-/var/lib/acfs/state.json}"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

is_valid_username() {
  local username="$1"
  [[ "$username" =~ ^[a-z_][a-z0-9_-]*$ ]]
}

resolve_home_for_user() {
  local user="$1"
  local user_home=""

  if [[ "$user" == "root" ]]; then
    printf '/root\n'
    return 0
  fi

  user_home="$(getent passwd "$user" 2>/dev/null | cut -d: -f6)" || true
  if [[ -n "$user_home" ]] && [[ "$user_home" == /* ]]; then
    printf '%s\n' "${user_home%/}"
    return 0
  fi

  return 1
}

read_target_user_from_state_file() {
  local state_file="$1"
  local target_user=""

  [[ -f "$state_file" ]] || return 1

  if command -v jq &>/dev/null; then
    target_user="$(jq -r '.target_user // empty' "$state_file" 2>/dev/null || true)"
  fi

  if [[ -z "$target_user" ]]; then
    target_user="$(sed -n 's/.*"target_user"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$state_file" | head -n 1)"
  fi

  if [[ -n "$target_user" ]] && is_valid_username "$target_user"; then
    printf '%s\n' "$target_user"
    return 0
  fi

  return 1
}

read_target_home_from_state_file() {
  local state_file="$1"
  local target_home=""

  [[ -f "$state_file" ]] || return 1

  if command -v jq &>/dev/null; then
    target_home="$(jq -r '.target_home // empty' "$state_file" 2>/dev/null || true)"
  fi

  if [[ -z "$target_home" ]]; then
    target_home="$(sed -n 's/.*"target_home"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$state_file" | head -n 1)"
  fi

  if [[ -n "$target_home" ]] && [[ "$target_home" == /* ]] && [[ "$target_home" != "/" ]]; then
    printf '%s\n' "${target_home%/}"
    return 0
  fi

  return 1
}

find_update_script_for_state_file() {
  local state_file="$1"
  local state_home=""
  local target_home=""
  local target_user=""
  local candidate_script=""

  [[ -f "$state_file" ]] || return 1

  if [[ "$state_file" == */.acfs/state.json ]]; then
    state_home="${state_file%/.acfs/state.json}"
    state_home="${state_home%/}"
    if [[ -n "$state_home" ]] && [[ "$state_home" == /* ]] && [[ "$state_home" != "/" ]]; then
      candidate_script="$(find_update_script_for_home "$state_home" 2>/dev/null || true)"
      if [[ -n "$candidate_script" ]]; then
        printf '%s\n' "$candidate_script"
        return 0
      fi

      # For home-adjacent state files, the path is a stronger signal than any
      # embedded target_user copied from another install.
      return 1
    fi
  fi

  target_home="$(read_target_home_from_state_file "$state_file" 2>/dev/null || true)"
  if [[ -n "$target_home" ]]; then
    candidate_script="$(find_update_script_for_home "$target_home" 2>/dev/null || true)"
    if [[ -n "$candidate_script" ]]; then
      printf '%s\n' "$candidate_script"
      return 0
    fi
  fi

  target_user="$(read_target_user_from_state_file "$state_file" 2>/dev/null || true)"
  [[ -n "$target_user" ]] || return 1
  find_update_script_for_user "$target_user"
}

find_wrapper_installed_home() {
  local candidate_home=""

  case "$SCRIPT_DIR" in
    */.local/bin)
      candidate_home="${SCRIPT_DIR%/.local/bin}"
      ;;
    */.acfs/bin)
      candidate_home="${SCRIPT_DIR%/.acfs/bin}"
      ;;
    *)
      return 1
      ;;
  esac

  [[ -n "$candidate_home" ]] || return 1
  [[ "$candidate_home" == /* ]] || return 1
  [[ "$candidate_home" != "/" ]] || return 1
  [[ -f "$candidate_home/.acfs/scripts/lib/update.sh" ]] || return 1

  printf '%s\n' "$candidate_home"
}

read_user_for_home() {
  local user_home="$1"
  local candidate_user=""
  local state_file=""
  local state_home=""

  [[ -n "$user_home" ]] || return 1
  state_file="$user_home/.acfs/state.json"
  user_home="${user_home%/}"

  candidate_user="$(
    getent passwd 2>/dev/null \
      | awk -F: -v home="$user_home" '$6 == home { print $1; exit }'
  )" || true
  if [[ -n "$candidate_user" ]] && is_valid_username "$candidate_user"; then
    printf '%s\n' "$candidate_user"
    return 0
  fi

  if command -v stat >/dev/null 2>&1; then
    candidate_user="$(stat -c '%U' "$user_home" 2>/dev/null || true)"
    if [[ -n "$candidate_user" ]] && [[ "$candidate_user" != "UNKNOWN" ]] && is_valid_username "$candidate_user"; then
      printf '%s\n' "$candidate_user"
      return 0
    fi
  fi

  candidate_user="$(read_target_user_from_state_file "$state_file" 2>/dev/null || true)"
  [[ -n "$candidate_user" ]] || return 1

  state_home="$(read_target_home_from_state_file "$state_file" 2>/dev/null || true)"
  if [[ -z "$state_home" ]]; then
    state_home="$(getent passwd "$candidate_user" 2>/dev/null | cut -d: -f6)" || true
    state_home="${state_home%/}"
  fi

  if [[ -n "$state_home" ]] && [[ "$state_home" == "$user_home" ]]; then
    printf '%s\n' "$candidate_user"
    return 0
  fi

  return 1
}

read_target_user_from_state_hint() {
  local state_file="$1"
  local candidate_user=""
  local state_home=""
  local target_home=""

  [[ -f "$state_file" ]] || return 1

  if [[ "$state_file" == */.acfs/state.json ]]; then
    state_home="${state_file%/.acfs/state.json}"
    state_home="${state_home%/}"
    if [[ -n "$state_home" ]] && [[ "$state_home" == /* ]] && [[ "$state_home" != "/" ]]; then
      candidate_user="$(read_user_for_home "$state_home" 2>/dev/null || true)"
      if [[ -n "$candidate_user" ]] && find_update_script_for_home "$state_home" >/dev/null 2>&1; then
        printf '%s\n' "$candidate_user"
        return 0
      fi

      # For home-adjacent state files, refuse to trust mismatched target_user
      # values from stale copies. The path itself is the stronger signal.
      return 1
    fi
  fi

  target_home="$(read_target_home_from_state_file "$state_file" 2>/dev/null || true)"
  if [[ -n "$target_home" ]] && find_update_script_for_home "$target_home" >/dev/null 2>&1; then
    candidate_user="$(read_user_for_home "$target_home" 2>/dev/null || true)"
    if [[ -z "$candidate_user" ]]; then
      candidate_user="$(read_target_user_from_state_file "$state_file" 2>/dev/null || true)"
    fi
    if [[ -n "$candidate_user" ]]; then
      printf '%s\n' "$candidate_user"
      return 0
    fi
  fi

  candidate_user="$(read_target_user_from_state_file "$state_file" 2>/dev/null || true)"
  if [[ -n "$candidate_user" ]] && user_has_installed_update_script "$candidate_user"; then
    printf '%s\n' "$candidate_user"
    return 0
  fi

  return 1
}

find_update_script_for_home() {
  local user_home="$1"

  [[ -n "$user_home" ]] || return 1

  if [[ -f "$user_home/.acfs/scripts/lib/update.sh" ]]; then
    printf '%s\n' "$user_home/.acfs/scripts/lib/update.sh"
    return 0
  fi

  return 1
}

home_from_update_script() {
  local update_script="$1"
  local user_home=""

  [[ -n "$update_script" ]] || return 1

  case "$update_script" in
    */.acfs/scripts/lib/update.sh)
      user_home="${update_script%/.acfs/scripts/lib/update.sh}"
      ;;
    *)
      return 1
      ;;
  esac

  [[ -n "$user_home" ]] || return 1
  [[ "$user_home" == /* ]] || return 1
  [[ "$user_home" != "/" ]] || return 1
  printf '%s\n' "${user_home%/}"
}

prepare_runtime_context_from_home() {
  local user_home="$1"

  [[ -n "$user_home" ]] || return 1
  [[ "$user_home" == /* ]] || return 1
  [[ "$user_home" != "/" ]] || return 1

  TARGET_HOME="$user_home"
  ACFS_HOME="$user_home/.acfs"
  ACFS_STATE_FILE="$ACFS_HOME/state.json"

  export TARGET_HOME ACFS_HOME ACFS_STATE_FILE
}

find_repo_local_update_script() {
  local candidate=""

  # Only treat this as a repo-local checkout when the wrapper lives under the
  # source tree next to the manifest. Direct installed-wrapper invocations from
  # ~/.acfs/bin still need owner detection before dispatch.
  if [[ -f "${SCRIPT_DIR}/lib/update.sh" ]] && [[ -f "${SCRIPT_DIR}/../acfs.manifest.yaml" ]]; then
    candidate="${SCRIPT_DIR}/lib/update.sh"
    # normalize path
    candidate="$(cd "$(dirname "$candidate")" && pwd)/$(basename "$candidate")"
    printf '%s\n' "$candidate"
    return 0
  fi

  return 1
}

find_update_script_for_user() {
  local user="$1"
  local user_home=""
  local current_user=""

  user_home="$(resolve_home_for_user "$user" || true)"
  if [[ -n "$user_home" ]] && find_update_script_for_home "$user_home" >/dev/null 2>&1; then
    find_update_script_for_home "$user_home"
    return 0
  fi

  current_user="$(id -un 2>/dev/null || whoami 2>/dev/null || true)"
  if [[ "$current_user" == "$user" ]] && [[ -n "${HOME:-}" ]] && [[ "${HOME}" == /* ]]; then
    user_home="${HOME%/}"
    if find_update_script_for_home "$user_home" >/dev/null 2>&1; then
      find_update_script_for_home "$user_home"
      return 0
    fi
  fi

  return 1
}

user_has_installed_update_script() {
  local user="$1"
  find_update_script_for_user "$user" >/dev/null 2>&1
}

find_installed_update_owner() {
  local current_user=""
  local entry=""
  local candidate_user=""
  local candidate_home=""

  current_user="$(whoami 2>/dev/null || true)"
  if [[ -n "$current_user" ]] && user_has_installed_update_script "$current_user"; then
    printf '%s\n' "$current_user"
    return 0
  fi

  while IFS=: read -r candidate_user _ _ _ _ candidate_home _; do
    [[ -n "$candidate_user" ]] || continue
    [[ -n "$candidate_home" ]] || continue
    [[ "$candidate_home" == /* ]] || continue
    if [[ -f "$candidate_home/.acfs/scripts/lib/update.sh" ]]; then
      printf '%s\n' "$candidate_user"
      return 0
    fi
  done < <(getent passwd 2>/dev/null || true)

  return 1
}

detect_target_user() {
  local state_candidate=""
  local candidate_user=""
  local wrapper_home=""
  local candidate_home=""

  wrapper_home="$(find_wrapper_installed_home 2>/dev/null || true)"
  if [[ -n "$wrapper_home" ]]; then
    candidate_user="$(read_user_for_home "$wrapper_home" 2>/dev/null || true)"
    if [[ -n "$candidate_user" ]]; then
      printf '%s\n' "$candidate_user"
      return 0
    fi
  fi

  if [[ -n "${ACFS_STATE_FILE:-}" ]]; then
    candidate_user="$(read_target_user_from_state_hint "$ACFS_STATE_FILE" 2>/dev/null || true)"
    if [[ -n "$candidate_user" ]]; then
      printf '%s\n' "$candidate_user"
      return 0
    fi
  fi

  if [[ -n "${ACFS_HOME:-}" ]]; then
    candidate_user="$(read_target_user_from_state_hint "${ACFS_HOME}/state.json" 2>/dev/null || true)"
    if [[ -n "$candidate_user" ]]; then
      printf '%s\n' "$candidate_user"
      return 0
    fi
  fi

  candidate_user="$(read_target_user_from_state_hint "$HOME/.acfs/state.json" 2>/dev/null || true)"
  if [[ -n "$candidate_user" ]]; then
    printf '%s\n' "$candidate_user"
    return 0
  fi

  while IFS=: read -r _ _ _ _ _ candidate_home _; do
    [[ -n "$candidate_home" ]] || continue
    [[ "$candidate_home" == /* ]] || continue
    state_candidate="$candidate_home/.acfs/state.json"
    candidate_user="$(read_target_user_from_state_hint "$state_candidate" 2>/dev/null || true)"
    if [[ -n "$candidate_user" ]]; then
      printf '%s\n' "$candidate_user"
      return 0
    fi
  done < <(getent passwd 2>/dev/null || true)

  candidate_user="$(read_target_user_from_state_hint "$ACFS_SYSTEM_STATE_FILE" 2>/dev/null || true)"
  if [[ -n "$candidate_user" ]]; then
    printf '%s\n' "$candidate_user"
    return 0
  fi

  candidate_user="$(find_installed_update_owner 2>/dev/null || true)"
  if [[ -n "$candidate_user" ]]; then
    printf '%s\n' "$candidate_user"
    return 0
  fi

  return 1
}

exec_as_target_user() {
  local user="$1"
  shift
  local -a env_args=()

  [[ -n "${ACFS_STATE_FILE:-}" ]] && env_args+=("ACFS_STATE_FILE=$ACFS_STATE_FILE")
  [[ -n "${ACFS_SYSTEM_STATE_FILE:-}" ]] && env_args+=("ACFS_SYSTEM_STATE_FILE=$ACFS_SYSTEM_STATE_FILE")
  [[ -n "${TARGET_HOME:-}" ]] && env_args+=("TARGET_HOME=$TARGET_HOME")
  [[ -n "${ACFS_HOME:-}" ]] && env_args+=("ACFS_HOME=$ACFS_HOME")
  [[ -n "${ACFS_REF:-}" ]] && env_args+=("ACFS_REF=$ACFS_REF")
  [[ -n "${ACFS_RAW:-}" ]] && env_args+=("ACFS_RAW=$ACFS_RAW")

  local cmd_with_env
  if [[ ${#env_args[@]} -gt 0 ]]; then
    cmd_with_env=("env" "${env_args[@]}" "$@")
  else
    cmd_with_env=("$@")
  fi

  if [[ "$EUID" -eq 0 ]]; then
    if command -v runuser >/dev/null 2>&1; then
      exec runuser -u "$user" -- "${cmd_with_env[@]}"
    fi
    if command -v sudo >/dev/null 2>&1; then
      exec sudo -u "$user" -H "${cmd_with_env[@]}"
    fi
    echo "Error: need runuser or sudo to run acfs-update as '$user'" >&2
    exit 1
  fi

  if ! command -v sudo >/dev/null 2>&1; then
    echo "Error: need sudo to run acfs-update as '$user'" >&2
    exit 1
  fi

  echo "Note: Running acfs-update as '$user' (ACFS owner)" >&2
  exec sudo -u "$user" -H "${cmd_with_env[@]}"
}

main() {
  local update_script=""
  local repo_update_script=""
  local target_user=""
  local current_user=""
  local wrapper_home=""
  local runtime_home=""
  local runtime_user=""
  local candidate_script=""

  repo_update_script="$(find_repo_local_update_script || true)"
  wrapper_home="$(find_wrapper_installed_home || true)"
  target_user="$(detect_target_user || true)"
  if [[ -n "$repo_update_script" ]]; then
    update_script="$repo_update_script"
  elif [[ -n "$wrapper_home" ]]; then
    ACFS_HOME="${ACFS_HOME:-$wrapper_home/.acfs}"
    ACFS_STATE_FILE="${ACFS_STATE_FILE:-$ACFS_HOME/state.json}"
    update_script="$(find_update_script_for_home "$wrapper_home" || true)"
    if [[ -z "$target_user" ]]; then
      target_user="$(read_user_for_home "$wrapper_home" || true)"
    fi
  fi

  if [[ -z "$update_script" ]] && [[ -n "${ACFS_STATE_FILE:-}" ]]; then
    candidate_script="$(find_update_script_for_state_file "$ACFS_STATE_FILE" 2>/dev/null || true)"
    [[ -n "$candidate_script" ]] && update_script="$candidate_script"
  fi

  if [[ -z "$update_script" ]] && [[ -n "${ACFS_HOME:-}" ]]; then
    candidate_script="$(find_update_script_for_state_file "${ACFS_HOME}/state.json" 2>/dev/null || true)"
    [[ -n "$candidate_script" ]] && update_script="$candidate_script"
  fi

  if [[ -z "$update_script" ]]; then
    candidate_script="$(find_update_script_for_state_file "$HOME/.acfs/state.json" 2>/dev/null || true)"
    [[ -n "$candidate_script" ]] && update_script="$candidate_script"
  fi

  if [[ -z "$update_script" ]]; then
    candidate_script="$(find_update_script_for_state_file "$ACFS_SYSTEM_STATE_FILE" 2>/dev/null || true)"
    [[ -n "$candidate_script" ]] && update_script="$candidate_script"
  fi

  if [[ -z "$update_script" ]] && [[ -n "$target_user" ]]; then
    update_script="$(find_update_script_for_user "$target_user" || true)"
  fi

  if [[ -z "${update_script:-}" ]]; then
    echo "Error: update.sh not found." >&2
    echo "Run from the repo or install ACFS first." >&2
    exit 1
  fi

  runtime_home="$(home_from_update_script "$update_script" 2>/dev/null || true)"
  if [[ -n "$runtime_home" ]]; then
    prepare_runtime_context_from_home "$runtime_home"
    runtime_user="$(read_user_for_home "$runtime_home" 2>/dev/null || true)"
    if [[ -n "$runtime_user" ]]; then
      target_user="$runtime_user"
    fi
  fi

  current_user="$(whoami)"
  if [[ -z "$target_user" || "$current_user" == "$target_user" ]]; then
    if [[ -n "${TARGET_HOME:-}" ]]; then
      exec env HOME="$TARGET_HOME" TARGET_HOME="$TARGET_HOME" ACFS_HOME="${ACFS_HOME:-$TARGET_HOME/.acfs}" bash "$update_script" "$@"
    fi
    exec bash "$update_script" "$@"
  fi

  exec_as_target_user "$target_user" bash "$update_script" "$@"
}

main "$@"
